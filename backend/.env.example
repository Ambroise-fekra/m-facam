NODE_ENV=development
PORT=3000

# Fournisseur de paiement : "mock" (simulateur local, sans PayPal) ou "paypal"
PAYMENT_PROVIDER=mock
# URL publique de l'API — sert à construire les liens de checkout mock
PUBLIC_API_URL=http://localhost:3000
# Email : "mock" (journalise) ou "smtp" (envoi réel via nodemailer). URL de l'app pour les liens.
EMAIL_PROVIDER=mock
APP_PUBLIC_URL=http://localhost:4200
# SMTP (requis si EMAIL_PROVIDER=smtp). Exemple Infomaniak :
SMTP_HOST=mail.infomaniak.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=

DB_HOST=localhost
DB_PORT=5432
DB_USER=facam
DB_PASSWORD=facam_dev_pwd
DB_MASTER_NAME=facam_master
DB_TEMPLATE_NAME=facam_template
# Mettre à true pour une base managée (Neon, Railway, RDS…). false en local.
DB_SSL=false

JWT_SECRET=replace-with-32-chars-random-string
JWT_EXPIRES_IN=1d

PAYPAL_MODE=sandbox
PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=
PAYPAL_SUBSCRIPTION_EMAIL=abo@familycash.example

SUBSCRIPTION_PRICE_EUR=20
TRIAL_DAYS=30

FCM_PROJECT_ID=
FCM_PRIVATE_KEY=
FCM_CLIENT_EMAIL=
